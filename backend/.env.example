# 默认 SQLite，生产环境可改为 PostgreSQL
DATABASE_URL=sqlite:///./ev_scheduler.db
# DATABASE_URL=postgresql://ev_user:ev_pass@localhost:5432/ev_scheduler
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173

# RL 后端：auto=PyTorch+GPU（优先 mamba_ssm）；numpy=纯 NumPy 轻量模式
RL_BACKEND=auto
USE_GPU=true
# DEVICE=cuda:0
BOOTSTRAP_EPISODES=80
PPO_LR=0.0003
